+    fn build_action(action_type: u8, expires_at: u64, data: &[u8]) -> Vec<u8> {
+        let mut buf = Vec::new();
+        buf.push(action_type);
+        buf.extend_from_slice(&(data.len() as u16).to_le_bytes());
+        buf.extend_from_slice(&expires_at.to_le_bytes());
+        buf.extend_from_slice(data);
+        buf
+    }
